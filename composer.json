{
  "name": "wordpress-parsi/wp-parsidate",
  "type": "project",
  "scripts": {
    "wp-parsidate-autload": "composer dump-autoload"
  },
  "autoload": {
    "psr-4": {
      "WPParsidate\\": "inc/"
    },
    "files": [
      "inc/Functions/Core.php",
      "inc/Functions/Old.php"
    ]
  },
  "config": {
    "optimize-autoloader": true
  },
  "authors": [
    {
      "name": "Parsa Kafi",
      "email": "parselearn@gmail.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "symfony/polyfill-php80": "^1.37.0",
    "symfony/polyfill-php81": "^1.38.1",
    "symfony/polyfill-php83": "^1.38",
    "enshrined/svg-sanitize": "^0.22.0"
  }
}
